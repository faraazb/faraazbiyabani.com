---
import { Image } from "astro:assets";
import Link from "@components/Link.astro";
import type { Experience } from "./experience.schema";
import { Icon } from "astro-icon/components";

interface Props {
  data: Experience;
}

const { data } = Astro.props;
const { heading, experiences } = data;
---

<section id="experience">
  <h2 class="header-2">{heading}</h2>
  <div class="experiences">
    {
      experiences.map((experience) => {
        const { roles, company } = experience;
        return (
          <div class="experience">
            <div class="company-icon-container">
              <a
                class="company-link"
                href={company.url}
                target="_blank"
                rel="noreferrer"
              >
                <Image
                  src={company.logo}
                  class="company-icon"
                  alt={`${company.title} logo`}
                />
              </a>
            </div>
            <div class="experience__information description">
              <Link
                type="secondary"
                icon="ph:building-office"
                href={company.url}
                target="_blank"
                rel="noreferrer"
              >
                {company.title}
              </Link>
              <ul class="roles">
                {roles.map(({ title, duration }) => (
                  <li class="role">
                    <div class="role__title">{title}</div>
                    <div class="role__duration">
                      <Icon name="ph:calendar-dots" />
                      <span>{duration}</span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style lang="scss">
  .roles {
    margin: 0;
    padding: 0.4rem;
    color: var(--secondary-foreground);
    display: flex;
    flex-direction: column;
    row-gap: 0.8rem;
  }

  .role {
    display: flex;
    flex-direction: column;
    row-gap: 8px;
  }

  .role__title {
    font-size: 1.2rem;
    // margin-bottom: 10px;
  }

  .role__duration {
    font-size: 1rem;
    display: flex;
    column-gap: 8px;
    align-items: center;
  }

  .icon-h {
    height: 16px;
    fill: var(--secondary-foreground);
  }

  .role__duration > .icon-h {
    height: 18px;
    width: 18px;
    margin-left: -3px;
  }

  // .company-link__title {
  //   // to offset the padding added by .underline-link
  //   margin-bottom: -2px;
  // }

  .experience__information {
    display: flex;
    flex-direction: column;
    row-gap: 0.4rem;
    padding: 5px;
  }
</style>
