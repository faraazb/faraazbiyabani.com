---
const isProduction = import.meta.env.PROD;
---

{
  isProduction ? (
    <>
      <script
        is:inline
        async
        defer
        src="https://simple.faraazbiyabani.com/latest.js"
      />
      <noscript>
        <img
          src="https://simple.faraazbiyabani.com/noscript.gif"
          alt=""
          referrerpolicy="no-referrer-when-downgrade"
        />
      </noscript>
    </>
  ) : null
}
