---
import type { HTMLAttributes } from "astro/types";
import faraaz from "../assets/images/faraaz.png";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const defaultTitle = title ?? "Faraaz Biyabani";
const defaultDescription = description ?? "Software Engineer at Contentstack";

const url = Astro.url;

const imageUrl = new URL(faraaz.src, url).toString();

const meta: HTMLAttributes<"meta">[] = [
  {
    property: "og:title",
    content: defaultTitle,
  },
  {
    property: "og:description",
    content: defaultDescription,
  },
  {
    name: "description",
    content: defaultDescription,
  },
  {
    property: "og:image",
    content: imageUrl,
  },
  {
    property: "og:url",
    content: url,
  },
  {
    property: "og:type",
    content: "website",
  },
  {
    name: "twitter:card",
    content: "summary",
  },
  {
    name: "twitter:title",
    content: defaultTitle,
  },
  {
    name: "twitter:url",
    content: url,
  },
  {
    name: "twitter:description",
    content: defaultDescription,
  },
  {
    name: "twitter:image",
    content: imageUrl,
  },
  {
    name: "twitter:creator",
    content: "@mfaraazb",
  },
  {
    name: "twitter:site",
    content: "@mfaraazb",
  },
];
---

{meta.map((item) => <meta {...item} />)}
